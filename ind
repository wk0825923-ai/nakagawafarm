// GAP進捗バー
function GapProgressBar({ pct }) {
  const color = pct >= 80 ? '#0A6B52' : pct >= 50 ? '#B45309' : '#DC2626'
  const bg    = pct >= 80 ? '#ECFDF5' : pct >= 50 ? '#FFFBEB' : '#FFF1F2'
  const border= pct >= 80 ? '#A7F3D0' : pct >= 50 ? '#FDE68A' : '#FECACA'
  return React.createElement('div', {
    style:{ background:bg, border:'1px solid '+border, borderRadius:'12px', padding:'16px 20px', marginBottom:'20px', display:'flex', alignItems:'center', gap:'20px' }
  },
    React.createElement('div', { style:{ flex:1 } },
      React.createElement('div', { style:{ display:'flex', justifyContent:'space-between', fontSize:'13px', marginBottom:'8px' } },
        React.createElement('span', { style:{ color:'#374151', fontWeight:500 } }, '📋 GAP認証 進捗'),
        React.createElement('span', { style:{ color, fontWeight:600 } }, pct + '%')
      ),
      React.createElement('div', { style:{ background:'#F4F6F9', borderRadius:'6px', height:'10px', overflow:'hidden' } },
        React.createElement('div', {
          style:{ height:'100%', borderRadius:'6px', background:color, width:pct+'%', transition:'width .8s ease' }
        })
      ),
      React.createElement('div', { style:{ fontSize:'11px', color:'#6B7280', marginTop:'6px' } },
        pct >= 80 ? '✓ 申請準備ができています' : pct >= 50 ? '引き続き項目をクリアしましょう' : '未完了の項目が多くあります'
      )
    ),
    React.createElement('div', { style:{ textAlign:'center', flexShrink:0 } },
      React.createElement('div', { style:{ fontSize:'32px', fontWeight:700, color, lineHeight:1 } }, pct + '%'),
      React.createElement('div', { style:{ fontSize:'10px', color:'#6B7280', marginTop:'4px' } }, '達成率')
    )
  )
}

// アラートカード（ビザ期限警告）
function AlertCard({ msg, days }) {
  const isUrgent = days <= 30
  return React.createElement('div', {
    style:{
      background: isUrgent ? '#FFF1F2' : '#FFFBEB',
      border: '1px solid ' + (isUrgent ? '#FECACA' : '#FDE68A'),
      
      borderRadius:'8px', padding:'12px 16px', marginBottom:'8px',
      display:'flex', alignItems:'center', gap:'12px'
    }
  },
    React.createElement('span', { style:{ fontSize:'18px' } }, isUrgent ? '🚨' : '⚠️'),
    React.createElement('div', { style:{ flex:1 } },
      React.createElement('div', { style:{ fontSize:'13px', color: isUrgent ? '#ff7070' : '#f9bc60', fontWeight:500 } }, msg),
      React.createElement('div', { style:{ fontSize:'11px', color:'#6B7280', marginTop:'2px' } }, isUrgent ? '至急対応が必要です' : '早めの手続きを推奨します')
    ),
    React.createElement('span', {
      className:'badge ' + (isUrgent ? 'badge-red' : 'badge-amber')
    }, '残' + days + '日')
  )
}

