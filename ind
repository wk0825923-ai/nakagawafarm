// B-2: 日々の記録フォーム（完全実装）
// ステップ型フォーム 4ステップ / 左フォーム + 右記録一覧 2カラム
// =====================================================
function DailyRecord({ fields, pesticides, records, onSave, hideList, hideForm }) {
  const [step, setStep]       = React.useState(1)
  const [dilution, setDilution] = React.useState(1000)
  const [form, setForm]       = React.useState({
    date: new Date().toISOString().slice(0,10),
    field_id: '', work_type: '', pesticide_id: '',
    amount: '', weather: '晴', worker: ''
  })
  const up = (k, v) => setForm(f => ({ ...f, [k]: v }))

  // 農薬バリデーション
  const selP   = pesticides.find(p => p.id === Number(form.pesticide_id))
  const usedT  = selP ? records.filter(r => r.field_id === Number(form.field_id) && r.pesticide_id === selP.id).length : 0
  const isOver = selP && usedT >= selP.max_times

  // 保存処理
  const handleSave = () => {
    if (!form.field_id || !form.work_type) return
    onSave({
      ...form, id: Date.now(), dilution,
      field_id: Number(form.field_id),
      pesticide_id: form.pesticide_id ? Number(form.pesticide_id) : null
    })
    setStep(1)
    setForm({ date: new Date().toISOString().slice(0,10), field_id:'', work_type:'', pesticide_id:'', amount:'', weather:'晴', worker:'' })
    setDilution(1000)
  }

  const STEPS    = ['日付・圃場', '作業内容', '農薬/施肥', '確認・保存']
  const WEATHERS = [{ v:'晴', icon:'☀️' }, { v:'曇', icon:'🌤' }, { v:'雨', icon:'🌧' }, { v:'強風', icon:'💨' }]
  const WORK_TYPES = [
    { v:'農薬散布', icon:'🧴', color:'#DC2626' },
    { v:'施肥',     icon:'🌿', color:'#0D9972' },
    { v:'除草',     icon:'✂️', color:'#D97706' },
    { v:'収穫',     icon:'🌾', color:'#7C3AED' },
    { v:'播種',     icon:'🌱', color:'#2563EB' },
    { v:'灌水',     icon:'💧', color:'#2563EB' },
    { v:'その他',   icon:'📝', color:'#6B7280' },
  ]

  const selField = fields.find(f => f.id === Number(form.field_id))

  // ステップインジケーター
  const StepBar = () => React.createElement('div', {
    style:{ display:'flex', alignItems:'center', marginBottom:'24px' }
  },
    ...STEPS.map((s, i) => [
      React.createElement('div', { key:'dot'+i, style:{ display:'flex', flexDirection:'column', alignItems:'center', gap:'4px' } },
        React.createElement('div', {
          style:{
            width:30, height:30, borderRadius:'50%', display:'flex', alignItems:'center', justifyContent:'center',
            fontSize:'12px', fontWeight:600, flexShrink:0,
            background: i+1 < step ? '#0A6B52' : i+1 === step ? '#FFFFFF' : '#F1F5F9',
            color:       i+1 < step ? '#FFFFFF' : i+1 === step ? '#0A6B52' : '#CBD5E1',
            border:      i+1 <= step ? '2px solid #0A6B52' : '1px solid #DDE2EC',
          }
        }, i+1 < step ? '✓' : i+1),
        React.createElement('div', { style:{ fontSize:'10px', color: i+1===step?'#0A6B52':'#94A3B8', whiteSpace:'nowrap' } }, s)
      ),
      i < STEPS.length-1 && React.createElement('div', { key:'line'+i, style:{ flex:1, height:'1px', background: i+1 < step ? '#0A6B52' : '#E2E8F0', margin:'0 6px', marginBottom:'18px' } })
    ]).flat().filter(Boolean)
  )

  // ステップ1: 日付・圃場・天気・作業者
  const Step1 = () => React.createElement('div', null,
    React.createElement('div', { className:'section-title' }, '📅 日付・圃場・作業者'),
    React.createElement('div', { style:{ display:'grid', gridTemplateColumns:'1fr 1fr', gap:'14px' } },
      React.createElement('div', { className:'form-group' },
        React.createElement('label', { className:'form-label' }, '作業日'),
        React.createElement('input', { type:'date', className:'form-input', value:form.date, onChange:e=>up('date',e.target.value) })
      ),
      React.createElement('div', { className:'form-group' },
        React.createElement('label', { className:'form-label' }, '作業者'),
        React.createElement('input', { type:'text', className:'form-input', value:form.worker, onChange:e=>up('worker',e.target.value), placeholder:'例: 田中 太郎' })
      )
    ),
    React.createElement('div', { className:'form-group' },
      React.createElement('label', { className:'form-label' }, '圃場を選択'),
      React.createElement('div', { style:{ display:'grid', gridTemplateColumns:'1fr 1fr', gap:'8px' } },
        ...fields.map(f =>
          React.createElement('button', {
            key: f.id,
            onClick: () => up('field_id', String(f.id)),
            style:{
              display:'flex', alignItems:'center', gap:'10px', padding:'12px 14px',
              borderRadius:'8px', cursor:'pointer', border:'1px solid',
              borderColor: form.field_id === String(f.id) ? f.color : '#DDE2EC',
              background:  form.field_id === String(f.id) ? f.color+'15' : '#F8FAFC',
              textAlign:'left'
            }
          },
            React.createElement('div', { style:{ width:10, height:10, borderRadius:'50%', background:f.color, flexShrink:0 } }),
            React.createElement('div', null,
              React.createElement('div', { style:{ fontSize:'13px', color:'#374151', fontWeight:500 } }, f.name),
              React.createElement('div', { style:{ fontSize:'11px', color:'#6B7280' } }, f.crop + ' / ' + f.area_are + 'a')
            )
          )
        )
      )
    ),
    React.createElement('div', { className:'form-group' },
      React.createElement('label', { className:'form-label' }, '天気'),
      React.createElement('div', { style:{ display:'flex', gap:'8px' } },
        ...WEATHERS.map(w =>
          React.createElement('button', {
            key: w.v,
            onClick: () => up('weather', w.v),
            style:{
              padding:'8px 16px', borderRadius:'8px', cursor:'pointer', fontSize:'13px', border:'1px solid',
              borderColor: form.weather === w.v ? '#0A6B52' : '#DDE2EC',
              background:  form.weather === w.v ? '#ECFDF5' : '#F8FAFC',
              color:       form.weather === w.v ? '#0A6B52' : '#64748B',
            }
          }, w.icon + ' ' + w.v)
        )
      )
    ),
    React.createElement('div', { style:{ display:'flex', justifyContent:'flex-end' } },
      React.createElement('button', { className:'btn btn-primary', disabled:!form.field_id, onClick:()=>setStep(2) }, '次へ →')
    )
  )

  // ステップ2: 作業内容（大ボタン選択）
  const Step2 = () => React.createElement('div', null,
    React.createElement('div', { className:'section-title' }, '🔧 作業内容を選択'),
    React.createElement('div', { style:{ display:'grid', gridTemplateColumns:'repeat(3, 1fr)', gap:'10px', marginBottom:'20px' } },
      ...WORK_TYPES.map(w =>
        React.createElement('button', {
          key: w.v,
          onClick: () => up('work_type', w.v),
          style:{
            display:'flex', flexDirection:'column', alignItems:'center', justifyContent:'center',
            gap:'8px', padding:'18px 12px', borderRadius:'10px', cursor:'pointer', border:'1px solid',
            borderColor: form.work_type === w.v ? w.color : '#DDE2EC',
            background:  form.work_type === w.v ? w.color+'18' : '#F8FAFC',
          }
        },
          React.createElement('span', { style:{ fontSize:'24px' } }, w.icon),
          React.createElement('span', { style:{ fontSize:'12px', fontWeight:500, color: form.work_type===w.v ? w.color : '#64748B' } }, w.v)
        )
      )
    ),
    React.createElement('div', { style:{ display:'flex', justifyContent:'space-between' } },
      React.createElement('button', { className:'btn btn-ghost', onClick:()=>setStep(1) }, '← 戻る'),
      React.createElement('button', { className:'btn btn-primary', disabled:!form.work_type, onClick:()=>setStep(3) }, '次へ →')
    )
  )

  // ステップ3: 農薬/施肥 詳細入力 ← B-3 PesticideInput を統合
  const Step3 = () => React.createElement('div', null,
    React.createElement('div', { className:'section-title' }, form.work_type === '農薬散布' ? '🧴 農薬情報' : '📊 作業量を入力'),
    form.work_type === '農薬散布' && React.createElement(PesticideInput, {
      pesticides, records,
      fieldId:     form.field_id,
      pesticideId: form.pesticide_id,
      onUpdate: ({ pesticide_id, dilution: d, volume: v, isOver: ov }) => {
        if (pesticide_id) up('pesticide_id', String(pesticide_id))
        setDilution(d)
        up('amount', v)
        // isOver を親で参照できるよう selP/isOver は既存ロジックがカバー
      }
    }),
    React.createElement('div', { style:{ display:'grid', gridTemplateColumns:'1fr 1fr', gap:'14px' } },
      React.createElement('div', { className:'form-group' },
        React.createElement('label', { className:'form-label' }, '使用量 / 作業量'),
        React.createElement('input', { type:'number', className:'form-input', value:form.amount, onChange:e=>up('amount',e.target.value), placeholder:'例: 50' })
      ),
      React.createElement('div', { className:'form-group' },
        React.createElement('label', { className:'form-label' }, '単位'),
        React.createElement('select', { className:'form-select' },
          React.createElement('option', null, 'L'),
          React.createElement('option', null, 'kg'),
          React.createElement('option', null, 'm²'),
        )
      )
    ),
    React.createElement('div', { style:{ display:'flex', justifyContent:'space-between' } },
      React.createElement('button', { className:'btn btn-ghost', onClick:()=>setStep(2) }, '← 戻る'),
      React.createElement('button', { className:'btn btn-primary', disabled:form.work_type==='農薬散布'&&isOver, onClick:()=>setStep(4) }, '確認 →')
    )
  )

  // ステップ4: 確認プレビュー → 保存
  const Step4 = () => {
    const rows = [
      ['📅 作業日', form.date],
      ['👤 作業者', form.worker || '—'],
      ['🌾 圃場',   selField ? selField.name + '（' + selField.crop + '）' : '—'],
      ['🔧 作業内容', form.work_type],
      ['🌤 天気',   form.weather],
      ...(form.work_type === '農薬散布' && selP ? [
        ['🧴 農薬',   selP.name],
        ['💧 希釈倍率', dilution + '倍'],
      ] : []),
      ['📊 使用量', form.amount ? form.amount + ' L/kg' : '—'],
    ]
    return React.createElement('div', null,
      React.createElement('div', { className:'section-title' }, '✅ 内容を確認して保存'),
      React.createElement('div', {
        style:{ background:'#F8FAFF', borderRadius:'10px', overflow:'hidden', marginBottom:'16px', boxShadow:'0 2px 8px rgba(17,24,39,.07)' }
      },
        ...rows.map(([k, v], i) =>
          React.createElement('div', {
            key: k,
            style:{ display:'flex', padding:'11px 16px', borderBottom: i < rows.length-1 ? '1px solid #F1F5F9' : 'none', fontSize:'13px' }
          },
            React.createElement('span', { style:{ color:'#6B7280', width:'120px', flexShrink:0 } }, k),
            React.createElement('span', { style:{ color:'#1A1F2E', fontWeight:500 } }, v)
          )
        )
      ),
      selField && React.createElement('div', {
        style:{ display:'flex', alignItems:'center', gap:'10px', padding:'10px 14px', background:selField.color+'12', border:'1px solid '+selField.color+'40', borderRadius:'8px', marginBottom:'16px', fontSize:'12px', color:'#374151' }
      },
        React.createElement('div', { style:{ width:8, height:8, borderRadius:'50%', background:selField.color } }),
        '保存すると ' + selField.name + ' の記録に追加されます'
      ),
      React.createElement('div', { style:{ display:'flex', justifyContent:'space-between' } },
        React.createElement('button', { className:'btn btn-ghost', onClick:()=>setStep(3) }, '← 戻る'),
        React.createElement('button', {
          className:'btn btn-primary',
          disabled: isOver,
          onClick: handleSave,
          style:{ padding:'10px 28px', fontSize:'14px' }
        }, '✓ 保存する')
      )
    )
  }

  // 記録一覧テーブル（右カラム）
  const RecordTable = () => {
    const workIconMap = { '農薬散布':'🧴','施肥':'🌿','除草':'✂️','収穫':'🌾','播種':'🌱','灌水':'💧','その他':'📝' }
    return React.createElement('div', null,
      React.createElement('div', { className:'section-title' }, '記録一覧（' + records.length + '件）'),
      React.createElement('div', { className:'card', style:{ padding:0 } },
        records.length === 0
          ? React.createElement('div', { style:{ padding:'24px', color:'#6B7280', fontSize:'13px', textAlign:'center' } }, '記録がまだありません')
          : React.createElement('table', { className:'table' },
              React.createElement('thead', null,
                React.createElement('tr', null,
                  ...['', '日付', '圃場', '作業', '天気', '作業者'].map(h => React.createElement('th', { key:h }, h))
                )
              ),
              React.createElement('tbody', null,
                ...[...records].reverse().map(r => {
                  const f = fields.find(x => x.id === r.field_id)
                  return React.createElement('tr', { key:r.id },
                    React.createElement('td', { style:{ paddingRight:0, fontSize:'15px' } }, workIconMap[r.work_type] || '📝'),
                    React.createElement('td', null, r.date),
                    React.createElement('td', null,
                      f && React.createElement('span', { style:{ display:'flex', alignItems:'center', gap:'6px' } },
                        React.createElement('div', { style:{ width:6, height:6, borderRadius:'50%', background:f.color } }),
                        f.name
                      )
                    ),
                    React.createElement('td', null, r.work_type),
                    React.createElement('td', { style:{ color:'#6B7280' } }, r.weather),
                    React.createElement('td', { style:{ color:'#6B7280' } }, r.worker || '—')
                  )
                })
              )
            )
      )
    )
  }

  const stepContent = [null, Step1, Step2, Step3, Step4][step]

  if (hideForm) return React.createElement('div', { className:'page' },
    React.createElement('div', { className:'page-title' }, '記録一覧'),
    React.createElement('div', { className:'page-sub', style:{marginBottom:'20px'} }, '全作業記録 '+records.length+'件'),
    React.createElement(RecordTable)
  )

  return React.createElement('div', { className:'page' },
    React.createElement('div', { className:'page-title' }, hideList ? '日次作業入力' : '日々の記録'),
    React.createElement('div', { className:'page-sub' }, '作業内容を記録してGAP書類を自動生成します'),

    // 2カラム: 左=フォーム / 右=記録一覧
    React.createElement('div', { style:{ display:'grid', gridTemplateColumns: hideList ? '1fr' : 'minmax(360px,420px) 1fr', gap:'24px', alignItems:'start' } },

      // 左: フォームカード
      React.createElement('div', { className:'card' },
        React.createElement(StepBar),
        stepContent && React.createElement(stepContent)
      ),

      // 右: 記録一覧（hideListのとき非表示）
      !hideList && React.createElement(RecordTable)
    )
  )
}

function FieldList({ fields, onAdd, onDelete, mapOnly, listOnly }) {
  const [showAdd,setShowAdd] = React.useState(false)
  const [form,setForm]       = React.useState({name:'',area_are:'',crop:'',status:'栽培中'})
  const mapRef         = React.useRef(null)
  const mapInstanceRef = React.useRef(null)
  const crops=['レタス','米','とうもろこし','ターサイ','トマト','大豆','玉ねぎ']
  const colors=['#0D9972','#D97706','#2563EB','#7C3AED','#DC2626']
  const handleAdd = () => {
    if (!form.name||!form.crop) return
    onAdd({...form,id:Date.now(),area_are:Number(form.area_are)||0,lat:35.384+Math.random()*.01,lng:139.924+Math.random()*.01,color:colors[fields.length%colors.length]})
    setForm({name:'',area_are:'',crop:'',status:'栽培中'}); setShowAdd(false)
  }
  // 作物カラーマップ（B-4仕様）
  const cropColorMap = { レタス:'#0D9972', 米:'#D97706', とうもろこし:'#EA580C', ターサイ:'#0891B2', トマト:'#DC2626', 大豆:'#7C3AED', 玉ねぎ:'#65A30D' }

  React.useEffect(()=>{
    if (!mapRef.current||mapInstanceRef.current) return
    const map = L.map(mapRef.current).setView([35.384,139.925],14)
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{attribution:'© OpenStreetMap'}).addTo(map)
    mapInstanceRef.current = map

    // B-4: マップクリックで新規圃場登録
    map.on('click', e => {
      const name = window.prompt('📍 新規圃場名を入力してください')
      if (!name || !name.trim()) return
      const crop = window.prompt('作物名を入力してください（例: レタス）') || 'その他'
      const area = Number(window.prompt('面積（a）を入力してください（例: 30）')) || 0
      onAdd({
        id:        Date.now(),
        name:      name.trim(),
        crop:      crop.trim(),
        area_are:  area,
        status:    '栽培中',
        lat:       e.latlng.lat,
        lng:       e.latlng.lng,
        color:     cropColorMap[crop.trim()] || colors[Math.floor(Math.random()*colors.length)],
      })
    })

    return ()=>{ map.remove(); mapInstanceRef.current=null }
  },[])
  React.useEffect(()=>{
    const map=mapInstanceRef.current; if (!map) return
    map.eachLayer(l=>{if (l instanceof L.CircleMarker) map.removeLayer(l)})
    fields.forEach(f=>L.circleMarker([f.lat,f.lng],{color:f.color,fillColor:f.color,fillOpacity:.7,radius:10,weight:2}).bindPopup('<b>'+f.name+'</b><br>'+f.crop+' / '+f.area_are+'a — '+f.status).addTo(map))
  },[fields])
  const listEl = React.createElement('div',null,
    ...fields.map(f=>React.createElement('div',{key:f.id,className:'field-card',style:{marginBottom:'8px',display:'flex',alignItems:'center',gap:'12px'}},
      React.createElement('div',{className:'field-dot',style:{background:f.color,width:12,height:12}}),
      React.createElement('div',{style:{flex:1}},
        React.createElement('div',{style:{fontSize:'14px',fontWeight:500,color:'#374151'}},f.name),
        React.createElement('div',{style:{fontSize:'12px',color:'#6B7280',marginTop:'2px'}},f.crop+' · '+f.area_are+'a')
      ),
      React.createElement('span',{className:'badge '+(f.status==='栽培中'?'badge-green':f.status==='休閑'?'badge-gray':f.status==='収穫期'?'badge-amber':'badge-blue')},f.status),
      React.createElement('button',{className:'btn',style:{padding:'4px 8px',fontSize:'12px',color:'#6B7280',background:'transparent',border:'1px solid #E5E9F0',borderRadius:'6px'},onClick:()=>onDelete(f.id)},'削除')
    ))
  )

  const mapEl = React.createElement('div',null,
    React.createElement('div',{ref:mapRef,id:'field-map'}),
    React.createElement('div',{style:{fontSize:'11px',color:'#6B7280',marginTop:'6px',textAlign:'center'}},'📍 地図上をクリックして新規圃場を登録できます')
  )

  const addFormEl = showAdd && React.createElement('div',{className:'card',style:{marginBottom:'16px'}},
    React.createElement('div',{className:'section-title'},'新規圃場登録'),
    React.createElement('div',{style:{display:'grid',gridTemplateColumns:'1fr 1fr',gap:'12px'}},
      React.createElement('div',{className:'form-group'},React.createElement('label',{className:'form-label'},'圃場名'),React.createElement('input',{type:'text',className:'form-input',value:form.name,onChange:e=>setForm(f=>({...f,name:e.target.value})),placeholder:'例: 第5圃場'})),
      React.createElement('div',{className:'form-group'},React.createElement('label',{className:'form-label'},'面積 (a)'),React.createElement('input',{type:'number',className:'form-input',value:form.area_are,onChange:e=>setForm(f=>({...f,area_are:e.target.value})),placeholder:'例: 25'})),
      React.createElement('div',{className:'form-group'},React.createElement('label',{className:'form-label'},'作物'),React.createElement('select',{className:'form-select',value:form.crop,onChange:e=>setForm(f=>({...f,crop:e.target.value}))},React.createElement('option',{value:''},'-- 選択 --'),...crops.map(c=>React.createElement('option',{key:c,value:c},c)))),
      React.createElement('div',{className:'form-group'},React.createElement('label',{className:'form-label'},'ステータス'),React.createElement('select',{className:'form-select',value:form.status,onChange:e=>setForm(f=>({...f,status:e.target.value}))},...['栽培中','休閑','収穫期','準備中'].map(s=>React.createElement('option',{key:s,value:s},s))))
    ),
    React.createElement('div',{style:{display:'flex',gap:'8px'}},React.createElement('button',{className:'btn btn-primary',disabled:!form.name||!form.crop,onClick:handleAdd},'登録'),React.createElement('button',{className:'btn btn-ghost',onClick:()=>setShowAdd(false)},'キャンセル'))
  )

  if (mapOnly) return React.createElement('div',{style:{display:'flex',flexDirection:'column',height:'100%',overflow:'hidden'}},
    React.createElement('div',{style:{padding:'16px 24px 12px',display:'flex',alignItems:'center',justifyContent:'space-between',flexShrink:0,borderBottom:'1px solid #DDE8DE',background:'#FAFBFA'}},
      React.createElement('div',null,
        React.createElement('div',{className:'page-title',style:{marginBottom:0}},'圃場マップ'),
        React.createElement('div',{style:{fontSize:'12px',color:'#64748B',marginTop:'2px'}},fields.length+'圃場登録済 — 地図上をクリックして新規登録')
      ),
      React.createElement('span',{style:{fontSize:'11px',color:'#94A3B8',background:'#F0F4F1',borderRadius:'6px',padding:'5px 10px'}},'📍 クリックで圃場追加')
    ),
    React.createElement('div',{ref:mapRef,style:{flex:1,minHeight:0}})
  )

  if (listOnly) return React.createElement('div',{className:'page'},
    React.createElement('div',{style:{display:'flex',alignItems:'center',justifyContent:'space-between',marginBottom:'6px'}},
      React.createElement('div',{className:'page-title'},'圃場一覧・管理'),
      React.createElement('button',{className:'btn btn-primary',onClick:()=>setShowAdd(!showAdd)},'+ 圃場を追加')
    ),
    React.createElement('div',{className:'page-sub'},fields.length+'圃場登録済 / 総面積: '+fields.reduce((a,f)=>a+f.area_are,0)+'a'),
    addFormEl,
    listEl
