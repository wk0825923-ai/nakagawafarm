// ・ビザ期限30日以内 → 赤バッジ（C-5仕様通り）
// ・30〜60日 → 黄バッジで事前警告
// ・期限切れ → 専用エラー表示
// ・ページ上部にアラートバナー（要対応者をまとめて表示）
// ・役割別統計サマリー
// ・ビザ期限昇順ソート（要対応者が上位に来る）
// =====================================================
function StaffList({ staff, onAdd, onDelete, visaOnly }) {
  const [form, setForm] = React.useState({ name:'', nationality:'JP', role:'worker', visa_expires_at:'' })

  const roleLabel = { manager:'管理者', worker:'一般作業員', trainee:'技能実習生' }
  const natLabel  = { JP:'🇯🇵 日本', VN:'🇻🇳 ベトナム', CN:'🇨🇳 中国', PH:'🇵🇭 フィリピン', ID:'🇮🇩 インドネシア' }
  const avatarPalette = ['#0A6B52','#1D4ED8','#B45309','#6D28D9','#C2410C','#0369A1','#047857']

  const getDaysLeft = (dateStr) => dateStr
    ? Math.ceil((new Date(dateStr) - new Date()) / 86400000)
    : null

  // ビザステータス判定（C-5仕様: 30日以内=赤）
  const getVisaStatus = (s) => {
    if (!s.visa_expires_at) return { type:'ok',    label:'在留問題なし',       badgeClass:'badge-green' }
    const d = getDaysLeft(s.visa_expires_at)
    if (d < 0)    return { type:'expired', label:'期限切れ',           badgeClass:'badge-red',   days:d }
    if (d <= 30)  return { type:'urgent',  label:'ビザ残'+d+'日',       badgeClass:'badge-red',   days:d }
    if (d <= 60)  return { type:'warn',    label:'ビザ残'+d+'日',       badgeClass:'badge-amber', days:d }
