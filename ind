<div id="app"></div>
<!-- C-2: GAP様式 農薬散布記録簿 PDFプレビュー（画面外に隠す） -->
<div id="pdf-preview"></div>
<div id="crop-plan-pdf-preview" style="display:none;position:fixed;left:-9999px;top:0"></div>
<script>
// =====================================================
// C-2: 農薬散布記録簿 PDF出力
// records → GAP様式HTMLテーブル → html2canvas → jsPDF
// 日本語対応: html2canvasがbodyフォントをそのままキャプチャするため
//             pdf-previewのfont-familyに日本語フォントを指定して対処
// =====================================================
async function exportSprayPDF(records, fields, pesticides) {
  const sprayRecords = records.filter(r => r.work_type === '農薬散布')
  const el = document.getElementById('pdf-preview')
  const today = new Date().toLocaleDateString('ja-JP', { year:'numeric', month:'long', day:'numeric' })

  // GAP様式テーブルHTML を生成
  el.innerHTML = `
    <h2>農薬散布記録簿</h2>
    <div class="pdf-meta">
      農園名: 中川農園　／　出力日: ${today}　／　対象件数: ${sprayRecords.length}件
    </div>
    <table>
      <thead>
        <tr>
          <th>No.</th>
          <th>作業日</th>
          <th>圃場名</th>
          <th>作物名</th>
          <th>農薬名</th>
          <th>登録番号</th>
          <th>希釈倍率</th>
          <th>散布量(L)</th>
          <th>天気</th>
          <th>作業者</th>
          <th>収穫前日数</th>
        </tr>
      </thead>
      <tbody>
        ${sprayRecords.length === 0
          ? '<tr><td colspan="11" style="text-align:center;color:#888;padding:16px">農薬散布記録がありません</td></tr>'
          : sprayRecords.map((r, i) => {
              const field = fields.find(f => f.id === r.field_id)
              const pest  = pesticides.find(p => p.id === r.pesticide_id)
              return `<tr>
                <td>${i + 1}</td>
                <td>${r.date}</td>
                <td>${field ? field.name : '—'}</td>
                <td>${field ? field.crop : '—'}</td>
                <td>${pest  ? pest.name  : '—'}</td>
                <td>${pest  ? pest.reg_no : '—'}</td>
                <td>${r.dilution ? r.dilution + '倍' : '—'}</td>
                <td>${r.amount || '—'}</td>
                <td>${r.weather || '—'}</td>
                <td>${r.worker || '—'}</td>
                <td>${pest ? pest.preharvest_days + '日' : '—'}</td>
              </tr>`
            }).join('')
        }
      </tbody>
    </table>
    <div class="pdf-footer">
      ※ 本記録はJGAP / GlobalGAP 農薬管理基準に基づき作成　中川農園
    </div>
  `

  // html2canvas でキャプチャ → jsPDF で出力
  const canvas = await html2canvas(el, { scale: 2, useCORS: true, logging: false })
  const { jsPDF } = window.jspdf
  const pdf   = new jsPDF('p', 'mm', 'a4')
  const imgW  = 190
  const imgH  = canvas.height * imgW / canvas.width
  pdf.addImage(canvas.toDataURL('image/png'), 'PNG', 10, 10, imgW, imgH)
  pdf.save('農薬散布記録簿_中川農園.pdf')

  // プレビューをリセット
  el.innerHTML = ''
}

// =====================================================
// C-3: 施肥記録 Excel出力（SheetJS）
// fertilizer_records モックデータを xlsx として出力
// =====================================================
function exportFertilizerExcel(records, fields) {
  const fertRecords = records.filter(r => r.work_type === '施肥')
  const data = fertRecords.map(r => {
    const field = fields.find(f => f.id === r.field_id)
    return {
      '日付':       r.date,
      '圃場名':     field ? field.name : '—',
      '作物名':     field ? field.crop : '—',
      '肥料名':     r.fertilizer_name || '（記録なし）',
      '施肥量(kg)': r.amount || 0,
      '作業者':     r.worker || '—',
      '天気':       r.weather || '—',
      '備考':       r.note || '',
    }
  })

  // データが0件でもヘッダー付きで出力
  const ws = XLSX.utils.json_to_sheet(
    data.length > 0 ? data : [{ '日付':'', '圃場名':'', '作物名':'', '肥料名':'', '施肥量(kg)':'', '作業者':'', '天気':'', '備考':'' }]
  )
  ws['!cols'] = [{ wch:12 },{ wch:15 },{ wch:15 },{ wch:20 },{ wch:12 },{ wch:15 },{ wch:8 },{ wch:20 }]

  const wb = XLSX.utils.book_new()
  XLSX.utils.book_append_sheet(wb, ws, '施肥記録')
  XLSX.writeFile(wb, '施肥記録簿_中川農園.xlsx')
}

